{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "chosen/hero",
  "title": "Hero",
  "category": "chosen",
  "icon": "format-image",
  "description": "Full-bleed photographic / video hero. Conference-led composition: National Catholic Youth Conference eyebrow → CHOSEN wordmark with medallion ornament → tagline (dates + venue) → Be Radiant theme chip → Register CTA.",
  "keywords": [
    "hero",
    "banner",
    "chosen",
    "conference"
  ],
  "supports": {
    "html": false,
    "anchor": true,
    "align": [
      "full"
    ],
    "spacing": {
      "margin": false,
      "padding": false
    }
  },
  "attributes": {
    "eyebrow": {
      "type": "string",
      "default": "National Catholic Youth Conference"
    },
    "wordmarkPart1": {
      "type": "string",
      "default": "CH"
    },
    "wordmarkPart2": {
      "type": "string",
      "default": "SEN"
    },
    "headlinePart1": {
      "type": "string",
      "default": ""
    },
    "headlinePart2": {
      "type": "string",
      "default": ""
    },
    "tagline": {
      "type": "string",
      "default": "19–22 November 2026 · La Trobe University, Melbourne"
    },
    "subhead": {
      "type": "string",
      "default": ""
    },
    "themeWord1": {
      "type": "string",
      "default": "Be"
    },
    "themeWord2": {
      "type": "string",
      "default": "Radiant"
    },
    "themeCite": {
      "type": "string",
      "default": "Psalm 34:5"
    },
    "themeChipLabel": {
      "type": "string",
      "default": ""
    },
    "themeChipCite": {
      "type": "string",
      "default": ""
    },
    "ctaLabel": {
      "type": "string",
      "default": "Register"
    },
    "backgroundImage": {
      "type": "object",
      "default": {
        "id": 0,
        "url": "",
        "alt": ""
      }
    },
    "enableRays": {
      "type": "boolean",
      "default": true
    },
    "enableKenBurns": {
      "type": "boolean",
      "default": false
    },
    "enableVideo": {
      "type": "boolean",
      "default": true
    }
  },
  "editorScript": "file:./index.js",
  "render": "file:./render.php"
}