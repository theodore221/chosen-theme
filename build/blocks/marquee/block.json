{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "chosen/marquee",
  "title": "Marquee",
  "category": "chosen",
  "icon": "controls-repeat",
  "description": "Infinite scrolling text strip, single-layer, intentional copy. Defaults to a CHOSEN-led conference signal: name, descriptor, dates, theme, cite. Pauses on hover; off with reduced motion.",
  "keywords": [
    "marquee",
    "ticker",
    "scrolling text"
  ],
  "supports": {
    "html": false,
    "anchor": true,
    "align": [
      "full"
    ]
  },
  "attributes": {
    "items": {
      "type": "array",
      "default": [
        {
          "text": "CHOSEN 2026",
          "color": "gold"
        },
        {
          "text": "National Catholic Youth Conference",
          "color": "white"
        },
        {
          "text": "19–22 November · La Trobe Melbourne",
          "color": "gold"
        },
        {
          "text": "Be Radiant",
          "color": "white"
        },
        {
          "text": "Psalm 34:5",
          "color": "gold",
          "cite": true
        }
      ]
    },
    "speed": {
      "type": "string",
      "default": "medium",
      "enum": [
        "slow",
        "medium",
        "fast"
      ]
    },
    "background": {
      "type": "string",
      "default": "cream",
      "enum": [
        "navy",
        "paper",
        "royal",
        "cream",
        "sage",
        "sky",
        "sun"
      ]
    }
  },
  "editorScript": "file:./index.js",
  "render": "file:./render.php"
}