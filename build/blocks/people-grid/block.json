{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "chosen/people-grid",
  "title": "People Grid",
  "category": "chosen",
  "icon": "groups",
  "description": "Circular-headshot grid for team / leadership / speakers. 3-up at desktop, 2-up tablet, 1-up mobile. Hover reveals name + role over a navy scrim.",
  "keywords": [
    "people",
    "team",
    "leaders",
    "headshots"
  ],
  "supports": {
    "html": false,
    "anchor": true,
    "align": [
      "full",
      "wide"
    ]
  },
  "attributes": {
    "eyebrow": {
      "type": "string",
      "default": "The team"
    },
    "heading": {
      "type": "string",
      "default": "Behind Chosen 2026"
    },
    "members": {
      "type": "array",
      "default": [
        {
          "name": "TBA",
          "role": "Conference Director",
          "photoStem": "dsc09854",
          "photoAlt": "Placeholder portrait"
        },
        {
          "name": "TBA",
          "role": "Programme Lead",
          "photoStem": "dsc00143",
          "photoAlt": "Placeholder portrait"
        },
        {
          "name": "TBA",
          "role": "Worship Coordinator",
          "photoStem": "dsc09433",
          "photoAlt": "Placeholder portrait"
        },
        {
          "name": "TBA",
          "role": "Hospitality Lead",
          "photoStem": "dsc00635",
          "photoAlt": "Placeholder portrait"
        },
        {
          "name": "TBA",
          "role": "Volunteer Coordinator",
          "photoStem": "dsc00238",
          "photoAlt": "Placeholder portrait"
        },
        {
          "name": "TBA",
          "role": "Communications",
          "photoStem": "img_4837",
          "photoAlt": "Placeholder portrait"
        }
      ]
    },
    "background": {
      "type": "string",
      "default": "paper",
      "enum": [
        "paper",
        "white",
        "navy",
        "cream",
        "sage",
        "sky",
        "sun",
        "coral"
      ]
    }
  },
  "editorScript": "file:./index.js",
  "render": "file:./render.php"
}